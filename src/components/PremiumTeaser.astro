---
// Contextual premium-workbook teaser shown at the end of a free chapter.
// The `sample` text is hand-authored teaser copy — it never un-strips premium MDX,
// so no paid content leaks and the sync/build/strip pipeline stays untouched.
//
// The Unlock CTA deep-links to the specific paired workbook via a single shared helper, so
// the in-chapter CTA and the exported manifest never drift and the destination stays
// single-sourced. The workbook slug is resolved from the title authored inline in each
// chapter, so chapters need not repeat the slug.
import { premiumCtaUrl, workbookSlugForTitle } from "../data/premium-pairings.mjs";

interface Props {
  workbookTitle: string;
  bridgeLine: string;
  bullets: string[];
  sample: { label: string; text: string };
  secondary?: string;
}

const { workbookTitle, bridgeLine, bullets, sample, secondary } = Astro.props;

const workbookSlug = workbookSlugForTitle(workbookTitle);
const ctaHref = premiumCtaUrl(workbookSlug);
// Chapter slug for conversion analytics — derived from the URL so chapters need no extra prop.
const chapter = Astro.url.pathname.replace(/^\/book\//, "").replace(/\/$/, "") || "index";
---

<aside
  class="premium-teaser"
  aria-label={`Premium workbook: ${workbookTitle}`}
  data-chapter={chapter}
  data-workbook={workbookSlug}
>
  <span class="premium-teaser__badge">🔒 Premium Workbook</span>
  <h3 class="premium-teaser__title">{workbookTitle}</h3>
  <p class="premium-teaser__bridge">{bridgeLine}</p>

  <ul class="premium-teaser__unlock">
    {bullets.map((b) => <li>{b}</li>)}
  </ul>

  <div class="premium-teaser__sample">
    <span class="premium-teaser__sample-label">{sample.label}</span>
    <p>{sample.text}</p>
  </div>

  <div class="premium-teaser__taste" hidden>
    <label class="premium-teaser__taste-label" for={`teaser-bill-${workbookSlug}`}>
      See what's at stake — enter your monthly electric bill:
    </label>
    <div class="premium-teaser__taste-row">
      <span class="premium-teaser__taste-prefix" aria-hidden="true">$</span>
      <input
        id={`teaser-bill-${workbookSlug}`}
        data-teaser-bill
        type="number"
        inputmode="numeric"
        min="0"
        step="10"
        placeholder="200"
      />
    </div>
    <output data-teaser-figure class="premium-teaser__taste-figure"></output>
  </div>

  {secondary && <p class="premium-teaser__secondary">{secondary}</p>}

  <a class="premium-teaser__cta" href={ctaHref}>
    Unlock the workbook <span aria-hidden="true">→</span>
  </a>
</aside>

<script>
  import { initPremiumTeasers } from "@solarpower101/visualization";

  initPremiumTeasers();
</script>
